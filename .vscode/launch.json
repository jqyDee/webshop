{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch App in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src/main/frontend/src"
    },

    {
      "name": "Launch React App",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "${workspaceFolder}/src/main/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "BROWSER": "none"
      }
    }
  ],
  "compounds": [
    {
      "name": "Launch and Debug App in Chrome",
      "configurations": ["Launch React App", "Launch App in Chrome"],
      "stopAll": true
    }
  ]
}
